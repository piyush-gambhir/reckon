load_env_file() {
  file="$1"
  if [ -f "$file" ]; then
    set -a
    . "$file"
    set +a
  fi
}

# Resolve the target before loading any credentials. Precedence:
#   RECKON_ENV (exported)  → wins if set
#   .reckon-env (file)     → else this, written by `scripts/reckon use <env>`
#   production             → else default
# The file exists so the active environment survives across shells without
# direnv. Its contents go through the SAME validation below, so a bad value
# there fails closed exactly like a bad variable.
reckon_env_requested="${RECKON_ENV:-}"
reckon_env_origin="RECKON_ENV"
if [ -z "$reckon_env_requested" ] && [ -f "$PWD/.reckon-env" ]; then
  reckon_env_requested="$(tr -d '[:space:]' < "$PWD/.reckon-env")"
  reckon_env_origin=".reckon-env"
fi

# Unknown values fail closed: no environment files are sourced and no real
# environment is selected.
case "$reckon_env_requested" in
  "")
    reckon_env=production
    printf '%s\n' 'reckon: no RECKON_ENV and no .reckon-env; defaulting to production'
    ;;
  production|staging|uat)
    reckon_env="$reckon_env_requested"
    ;;
  *)
    printf '%s\n' "reckon: ERROR: invalid environment '${reckon_env_requested}' (from ${reckon_env_origin}). Valid values: production, staging, uat" >&2
    return 1
    ;;
esac

export RECKON_ENV="$reckon_env"
if [ "$RECKON_ENV" = production ]; then
  printf '%s\n' '!!! reckon: ENV=production (PRODUCTION) !!!'
else
  printf '%s\n' "=== reckon: ENV=$RECKON_ENV ==="
fi

export XDG_CONFIG_HOME="$PWD/.config/$RECKON_ENV"

# Load folder-local credentials without requiring interactive CLI logins.
# Later files override earlier ones. Use the resolved value for filenames so a
# value inside .env.common cannot redirect credential loading.
load_env_file .env.common
load_env_file ".env.$reckon_env"
load_env_file ".env.$reckon_env.local"
export RECKON_ENV="$reckon_env"
export XDG_CONFIG_HOME="$PWD/.config/$reckon_env"

# Compatibility aliases for common variable names.
if [ -n "${JENKINS_USERNAME:-}" ] && [ -z "${JENKINS_USER:-}" ]; then
  export JENKINS_USER="$JENKINS_USERNAME"
fi

if [ -n "${CUBEAPM_HOST:-}" ] && [ -z "${CUBEAPM_SERVER:-}" ]; then
  export CUBEAPM_SERVER="$CUBEAPM_HOST"
fi

# AWS CLI does not honour XDG_CONFIG_HOME natively. Pin its config and
# credentials files into this workspace so `aws configure` writes here,
# not into ~/.aws.
export AWS_CONFIG_FILE="$XDG_CONFIG_HOME/aws/config"
export AWS_SHARED_CREDENTIALS_FILE="$XDG_CONFIG_HOME/aws/credentials"

# kubectl: keep cluster contexts workspace-local too, so production contexts
# never leak into ~/.kube/config (and vice versa). Populate with:
#   aws eks update-kubeconfig --name <cluster> --region "$AWS_REGION"
export KUBECONFIG="$XDG_CONFIG_HOME/kube/config"

# GitHub CLI already respects XDG_CONFIG_HOME, so .config/gh/ is workspace-local.
# Allow GITHUB_TOKEN as an alias for GH_TOKEN so either spelling in an env file works.
if [ -n "${GITHUB_TOKEN:-}" ] && [ -z "${GH_TOKEN:-}" ]; then
  export GH_TOKEN="$GITHUB_TOKEN"
fi

# Database CLI safety defaults — applied if the env files didn't already set them.
# Postgres: libpq honours PGOPTIONS, so every session opens read-only by
# default. This blocks *accidental* writes; a session can still opt back in with
# BEGIN READ WRITE, so the read-only DB role remains the real write barrier.
: "${PGOPTIONS:=-c statement_timeout=30s -c default_transaction_read_only=on}"
export PGOPTIONS

# MySQL: the client has no init-command environment variable (and MYSQL_USER /
# MYSQL_DATABASE are not client env vars either), so fold the read-only session
# default plus user/database into a workspace-local option file. Invoke mysql as
#   mysql --defaults-extra-file="$XDG_CONFIG_HOME/mysql/my.cnf"
# The password stays in MYSQL_PWD (env) and host/port in MYSQL_HOST/MYSQL_TCP_PORT.
if [ -n "${MYSQL_HOST:-}" ]; then
  mkdir -p "$XDG_CONFIG_HOME/mysql"
  ( umask 077
    {
      echo "[client]"
      echo "init-command=SET SESSION TRANSACTION READ ONLY"
      [ -n "${MYSQL_USER:-}" ]     && echo "user=${MYSQL_USER}"
      [ -n "${MYSQL_DATABASE:-}" ] && echo "database=${MYSQL_DATABASE}"
    } > "$XDG_CONFIG_HOME/mysql/my.cnf" )
fi

# Kafka: rpk reads RPK_* env vars, not KAFKA_*. Derive them so the documented
# `rpk ... --brokers "$KAFKA_BOOTSTRAP_SERVERS"` commands can actually
# authenticate against a SASL/TLS cluster. (kcat takes everything via -X flags.)
if [ -n "${KAFKA_BOOTSTRAP_SERVERS:-}" ]; then
  : "${RPK_BROKERS:=$KAFKA_BOOTSTRAP_SERVERS}"; export RPK_BROKERS
  case "${KAFKA_SECURITY_PROTOCOL:-}" in
    SASL_SSL|SASL_PLAINTEXT)
      : "${RPK_USER:=${KAFKA_SASL_USERNAME:-}}"; export RPK_USER
      : "${RPK_PASS:=${KAFKA_SASL_PASSWORD:-}}"; export RPK_PASS
      : "${RPK_SASL_MECHANISM:=${KAFKA_SASL_MECHANISM:-}}"; export RPK_SASL_MECHANISM
      ;;
  esac
  case "${KAFKA_SECURITY_PROTOCOL:-}" in
    SASL_SSL|SSL) : "${RPK_TLS_ENABLED:=true}"; export RPK_TLS_ENABLED ;;
  esac
fi

# Elasticsearch (optional log store): es-cli enforces read-only at the client
# when ES_READ_ONLY is set — mutating commands are refused before any request.
# Same belt-and-suspenders posture as PGOPTIONS: the ES role should be
# read-only too; this guards against a misconfigured role.
: "${ES_READ_ONLY:=true}"
export ES_READ_ONLY

# ClickHouse (optional analytics/event store): only apply client defaults when
# a host is configured. Every query must still pass --readonly=1 explicitly;
# the server-side readonly=1 user profile remains the real write barrier.
if [ -n "${CLICKHOUSE_HOST:-}" ]; then
  : "${CLICKHOUSE_PORT:=9440}"
  : "${CLICKHOUSE_SECURE:=1}"
  export CLICKHOUSE_HOST CLICKHOUSE_PORT CLICKHOUSE_USER CLICKHOUSE_PASSWORD
  export CLICKHOUSE_DATABASE CLICKHOUSE_SECURE
fi
