export XDG_CONFIG_HOME="$PWD/.config"

load_env_file() {
  file="$1"
  if [ -f "$file" ]; then
    set -a
    . "$file"
    set +a
  fi
}

# Load folder-local credentials without requiring interactive CLI logins.
load_env_file .env
load_env_file .env.local

# Compatibility aliases for common variable names.
if [ -n "${JENKINS_USERNAME:-}" ] && [ -z "${JENKINS_USER:-}" ]; then
  export JENKINS_USER="$JENKINS_USERNAME"
fi

if [ -n "${CUBEAPM_HOST:-}" ] && [ -z "${CUBEAPM_SERVER:-}" ]; then
  export CUBEAPM_SERVER="$CUBEAPM_HOST"
fi
